@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

@* This component redirects to the landing page with a toast when auth fails.
    No longer shows the full-screen overlay — the user just sees a brief notification
    and is sent to the landing page where the auth challenge takes over. *@

@code {
    protected override async Task OnInitializedAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("showToast", "Session expired. Redirecting to login...");
        }
        catch
        {
            // JS interop might not be available during prerendering — ignore
        }

        // Small delay so the toast is visible before redirecting
        await Task.Delay(1500);
        Navigation.NavigateTo("/logout", forceLoad: true);
    }
}
