@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using System.Text.Json.Serialization
@inject IConfiguration Configuration
@inject IJSRuntime JSRuntime
@inject ITokenAcquisitionService TokenService
@implements IAsyncDisposable

@if (_alerts.Count > 0)
{
    foreach (var alert in _alerts.ToArray())
    {
        var relativeTime = ComputeRelativeTime(alert.StartsAtUtc);
        <div class="toast toast--low" data-testid="meeting-alert-toast-content">
            <div class="toast__icon">
                <span class="material-symbols-outlined">calendar_month</span>
            </div>
            <div class="toast__body">
                <div class="toast__header">
                    <span class="toast__badge">Meeting</span>
                    <h3 class="toast__title" data-testid="meeting-alert-title">@alert.Title</h3>
                    <button class="toast__dismiss"
                            data-testid="meeting-alert-dismiss"
                            @onclick="() => DismissAlert(alert)"
                            aria-label="Dismiss alert">
                        &times;
                    </button>
                </div>
                <p class="toast__source" data-testid="meeting-alert-time">@relativeTime</p>
                <div class="toast__actions">
                    <button class="toast__acknowledge"
                            data-testid="meeting-alert-acknowledge"
                            @onclick="() => AcknowledgeAlert(alert)">
                        Acknowledge
                    </button>
                </div>
            </div>
        </div>
    }
}

@code {
    private HubConnection? _hubConnection;
    private readonly List<MeetingAlertPayload> _alerts = [];
    private readonly object _lock = new();

    protected override async Task OnInitializedAsync()
    {
        await TryConnectWithRetryAsync();
    }

    private async Task TryConnectWithRetryAsync(int maxRetries = 3, int delayMs = 1000)
    {
        for (int attempt = 1; attempt <= maxRetries; attempt++)
        {
            try
            {
                var token = await TokenService.AcquireTokenAsync();

                if (string.IsNullOrEmpty(token))
                {
                    Console.WriteLine($"SignalR: Token not available for meeting toast (attempt {attempt}/{maxRetries})");
                    if (attempt < maxRetries)
                        await Task.Delay(delayMs);
                    continue;
                }

                var baseUrl = Configuration.GetValue<string>("AuraApi:BaseUrl")?.TrimEnd('/')
                              ?? string.Empty;
                var hubUrl = string.IsNullOrEmpty(baseUrl)
                    ? "/hubs/alerts"
                    : $"{baseUrl}/hubs/alerts";

                _hubConnection = new HubConnectionBuilder()
                    .WithUrl(hubUrl, options =>
                    {
                        options.AccessTokenProvider = () => Task.FromResult(token)!;
                    })
                    .WithAutomaticReconnect()
                    .Build();

                _hubConnection.On<MeetingAlertPayload>("MeetingAlert", alert =>
                {
                    lock (_lock)
                    {
                        _alerts.Add(alert);
                    }
                    InvokeAsync(async () =>
                    {
                        StateHasChanged();
                        await ShowBrowserNotification(alert);
                        await PlayAlertSound();
                    });
                });

                await _hubConnection.StartAsync();
                Console.WriteLine("SignalR: Meeting toast connection established");
                return; // Success
            }
            catch (Exception ex)
            {
                Console.WriteLine($"SignalR: Meeting toast connection failed (attempt {attempt}/{maxRetries}): {ex.Message}");
                if (attempt < maxRetries)
                    await Task.Delay(delayMs);
            }
        }

        Console.WriteLine("SignalR: Failed to establish meeting toast connection after all retries - meeting alerts will not be shown");
    }

    private static string ComputeRelativeTime(DateTimeOffset startsAtUtc)
    {
        var now = DateTimeOffset.UtcNow;
        if (startsAtUtc <= now)
            return "Starting now";

        var diff = startsAtUtc - now;
        if (diff.TotalHours >= 1)
        {
            var hours = (int)diff.TotalHours;
            var minutes = diff.Minutes;
            return minutes > 0
                ? $"Starts in {hours}h {minutes}m"
                : $"Starts in {hours}h";
        }

        if (diff.TotalMinutes >= 1)
            return $"Starts in {(int)diff.TotalMinutes}m";

        return "Starting soon";
    }

    private async Task ShowBrowserNotification(MeetingAlertPayload alert)
    {
        try
        {
            var time = ComputeRelativeTime(alert.StartsAtUtc);
            await JSRuntime.InvokeVoidAsync("meetingAlert.showNotification", alert.Title, time);
        }
        catch (JSException)
        {
            // JS interop not available (e.g., during prerendering)
        }
    }

    private async Task PlayAlertSound()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("meetingAlert.playSound");
        }
        catch (JSException)
        {
            // JS interop not available
        }
    }

    private async Task AcknowledgeAlert(MeetingAlertPayload alert)
    {
        if (_hubConnection is not null)
        {
            try
            {
                await _hubConnection.InvokeAsync("AcknowledgeAlert", alert.EventId);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Failed to acknowledge alert: {ex.Message}");
            }
        }

        lock (_lock)
        {
            _alerts.Remove(alert);
        }
        StateHasChanged();
    }

    private void DismissAlert(MeetingAlertPayload alert)
    {
        lock (_lock)
        {
            _alerts.Remove(alert);
        }
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

    /// <summary>
    /// Maps the SignalR MeetingAlert payload sent by SignalRMeetingAlertDispatcher.
    /// </summary>
    public class MeetingAlertPayload
    {
        [JsonPropertyName("eventId")]
        public string EventId { get; set; } = string.Empty;

        [JsonPropertyName("title")]
        public string Title { get; set; } = string.Empty;

        [JsonPropertyName("startsAtUtc")]
        public DateTimeOffset StartsAtUtc { get; set; }

        [JsonPropertyName("joinUrl")]
        public string? JoinUrl { get; set; }
    }
}
