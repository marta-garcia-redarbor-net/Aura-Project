@page "/dashboard"
@using Microsoft.AspNetCore.Components.Authorization
@using Aura.UI.Components.Auth
@using Aura.UI.Services
@using System.Net.Http.Json
@inject IDashboardPreviewApiClient DashboardPreviewApiClient
@inject NavigationManager Navigation
@inject IDashboardEventBus EventBus
@inject IHttpClientFactory HttpClientFactory
@implements IDisposable

<AuthorizeView>
    <Authorized>
        <PageTitle>Aura - Priority Dashboard</PageTitle>

        @if (_showLoginOverlay)
        {
            <RestrictedAccessView />
        }
        else
        {
            <div class="dashboard-page-header">
                <div>
                    <h1 class="dashboard-page-header__title">Priority Dashboard</h1>
                </div>
                <div style="display:flex;align-items:center;gap:0.75rem;">
                    @if (_demoAvailable)
                    {
                        <button class="dashboard-header__demo-btn"
                                disabled="@_simulationRunning"
                                @onclick="StartSimulationAsync"
                                title="@_simulationMessage">
                            <span class="material-symbols-outlined">play_circle</span>
                            Demo Mode
                        </button>
                        <button class="dashboard-header__reset-btn"
                                disabled="@_simulationRunning"
                                @onclick="ResetDemoAsync"
                                title="Delete demo items">
                            <span class="material-symbols-outlined">delete</span>
                            Reset
                        </button>
                    }
                    <button class="dashboard-header__nav-active dashboard-header__top-priority-link"
                            data-testid="priority-dashboard-top-priority-counter"
                            @onclick="NavigateToTopPriority"
                            aria-label="Open top priority queue"
                            title="Open top priority queue">
                        <span class="dashboard-page-header__badge dashboard-page-header__badge--live"
                              data-testid="priority-dashboard-pending-badge">
                            @_previewSummary?.TotalPendingCount pending
                        </span>
                        <span class="dashboard-page-header__badge dashboard-page-header__badge--high"
                              data-testid="priority-dashboard-high-badge">
                            @_previewSummary?.HighPriorityCount high priority
                        </span>
                    </button>
                </div>
            </div>

            <PrioritySummaryCards />
        }
    </Authorized>
    <NotAuthorized>
        <PageTitle>Aura | Acceso Requerido</PageTitle>
        <RedirectToLanding />
    </NotAuthorized>
</AuthorizeView>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    private DashboardPreviewResponse? _previewSummary;
    private bool _showLoginOverlay;
    private bool _demoAvailable;
    private bool _simulationRunning;
    private string? _simulationMessage;
    private bool _demoDataExists;

    protected override async Task OnInitializedAsync()
    {
        EventBus.OnDashboardRefresh += HandleDashboardRefresh;
        await CheckDemoStatusAsync();
        await RefreshDataAsync();
    }

    private async Task CheckDemoStatusAsync()
    {
        if (AuthenticationState is not null)
        {
            var authState = await AuthenticationState;
            _demoAvailable = authState.User.HasClaim("aura_demo_mode", "true");
        }
    }

    private async Task StartSimulationAsync()
    {
        _simulationRunning = true;
        _simulationMessage = null;
        try
        {
            var beforePending = _previewSummary?.TotalPendingCount ?? 0;
            var client = HttpClientFactory.CreateClient("AuraApi");
            var response = await client.PostAsync("api/demo/start-simulation", null);
            response.EnsureSuccessStatusCode();
            await EventBus.RaiseDashboardRefreshAsync();
            await RefreshDataAsync();
            for (var attempt = 0; attempt < 6; attempt++)
            {
                await Task.Delay(3000);
                await RefreshDataAsync();
                if ((_previewSummary?.TotalPendingCount ?? 0) > beforePending)
                {
                    await EventBus.RaiseDashboardRefreshAsync();
                    await RefreshDataAsync();
                    break;
                }
            }
            await InvokeAsync(StateHasChanged);
            _simulationMessage = $"✅ Simulación iniciada ({_previewSummary?.TotalPendingCount ?? 0} pending)";
            _demoDataExists = true;
        }
        catch
        {
            _simulationMessage = "❌ Error al iniciar";
        }
        finally
        {
            _simulationRunning = false;
        }
    }

    private async Task ResetDemoAsync()
    {
        _simulationRunning = true;
        try
        {
            var client = HttpClientFactory.CreateClient("AuraApi");
            var response = await client.PostAsync("api/demo/reset", null);
            response.EnsureSuccessStatusCode();
            _demoDataExists = false;
            _simulationMessage = null;
            EventBus.ClearTracking();
            await EventBus.RaiseDashboardRefreshAsync();
            await RefreshDataAsync();
        }
        catch
        {
            _simulationMessage = "❌ Error al resetear demo";
        }
        finally
        {
            _simulationRunning = false;
        }
    }

    private async Task HandleDashboardRefresh()
    {
        await RefreshDataAsync();
        StateHasChanged();
    }

    private async Task RefreshDataAsync()
    {
        try
        {
            _previewSummary = await DashboardPreviewApiClient.GetPreviewAsync(CancellationToken.None);
            _showLoginOverlay = false;
        }
        catch (UnauthorizedAccessException)
        {
            _showLoginOverlay = true;
        }
        catch
        {
            // Keep last known state on transient errors
        }
    }

    public void Dispose()
    {
        EventBus.OnDashboardRefresh -= HandleDashboardRefresh;
    }

    private void NavigateToTopPriority()
        => Navigation.NavigateTo("/top-priority");
}
