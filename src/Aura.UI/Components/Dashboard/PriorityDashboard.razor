@page "/dashboard"
@using Microsoft.AspNetCore.Components.Authorization
@using Aura.UI.Components.Auth
@using Aura.UI.Models
@using Aura.UI.Services
@using System.Net.Http.Json
@using Microsoft.JSInterop
@inject IDashboardPreviewApiClient DashboardPreviewApiClient
@inject IDashboardEventBus EventBus
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject DemoUiState DemoState
@implements IDisposable

<AuthorizeView>
    <Authorized>
        <PageTitle>Aura - Priority Dashboard</PageTitle>

        @if (_redirecting)
        {
            <p style="padding:2rem;text-align:center;color:var(--aura-on-surface-variant);">
                Session expired. Redirecting...
            </p>
        }
        else
        {
            <DashboardStatePanel State="@_layoutState" />
            @if (_layoutState is not null && _layoutState.Kind == DashboardViewStateKind.Populated)
            {
                <DashboardCards Cards="_layoutState.Cards" />
            }

            <FocusStatePanel />
            <SystemStatusPanel />
            <ModuleProgressPanel />
            <SyncStatusPanel />
            <InboxPreviewPanel />
            <MorningSummaryPreviewPanel />
            <GraphConnectorStatusPanel />
        }
    </Authorized>
    <NotAuthorized>
        <PageTitle>Aura | Acceso Requerido</PageTitle>
        <RedirectToLanding />
    </NotAuthorized>
</AuthorizeView>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    [CascadingParameter]
    private DashboardViewState? _layoutState { get; set; }

    private DashboardPreviewResponse? _previewSummary;
    private bool _redirecting;

    protected override async Task OnInitializedAsync()
    {
        EventBus.OnDashboardRefresh += HandleDashboardRefresh;
        await RefreshDataAsync();

        // Keep DemoState in sync with preview data
        if (AuthenticationState is not null)
        {
            var authState = await AuthenticationState;
            if (authState.User.HasClaim("aura_demo_mode", "true"))
            {
                DemoState.IsDemoUser = true;
            }
        }
    }

    private async Task HandleDashboardRefresh()
    {
        await RefreshDataAsync();
        StateHasChanged();
    }

    private async Task RefreshDataAsync()
    {
        try
        {
            _previewSummary = await DashboardPreviewApiClient.GetPreviewAsync(CancellationToken.None);
        }
        catch (UnauthorizedAccessException)
        {
            _redirecting = true;
            StateHasChanged();
            try { await JSRuntime.InvokeVoidAsync("showToast", "Session expired. Redirecting to login..."); } catch { }
            await Task.Delay(1500);
            Navigation.NavigateTo("/logout", forceLoad: true);
        }
        catch
        {
            // Keep last known state on transient errors
        }
    }

    public void Dispose()
    {
        EventBus.OnDashboardRefresh -= HandleDashboardRefresh;
    }
}
