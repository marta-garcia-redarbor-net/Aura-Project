@using Aura.UI.Models
@using Aura.UI.Services
@inject IPrioritySummaryService PrioritySummaryService

<section class="priority-summary-cards" data-testid="priority-summary-cards" aria-label="Items grouped by source">
    @if (_loadError is not null)
    {
        <div class="dashboard-panel dashboard-panel--error" data-testid="priority-cards-error">
            <p style="color: var(--aura-error);">@_loadError</p>
        </div>
    }
    else if (_cards is null)
    {
        <div class="dashboard-panel dashboard-panel--loading" data-testid="priority-cards-loading">
            <p>Loading priority summary...</p>
        </div>
    }
    else
    {
        @foreach (var card in _cards)
        {
            var isEmpty = card.TotalCount == 0;

            <article class="priority-card priority-card--@card.CssClass @(isEmpty ? "priority-card--empty" : "")"
                     data-testid="priority-card" data-source="@card.CssClass">

                <header class="priority-card__header">
                    <span class="material-symbols-outlined" style="font-size: 20px; color: var(--aura-on-surface-variant);">@card.Icon</span>
                    <h3 class="priority-card__level">@card.DisplayName</h3>
                    @if (PriorityPresentation.HasTopPriorityItems(card.PreviewItems) || (card.IsPrCard && PriorityPresentation.HasTopPriorityPrItems(card.PrItems)))
                    {
                        <span class="top-priority-indicator" data-testid="priority-card-top-badge" title="Top priority" aria-label="Top priority"></span>
                    }
                    <div class="priority-card__header-counts">
                        <span class="priority-card__count" data-testid="priority-card-count">
                            @card.TotalCount @card.CountLabel
                        </span>
                        @if (!card.IsCalendarCard)
                        {
                            var highPriorityCount = card.IsPrCard
                                ? PriorityPresentation.GetHighPriorityPrCount(card.PrItems)
                                : PriorityPresentation.GetHighPriorityCount(card.PreviewItems);

                            <span class="priority-card__high-count"
                                  data-testid="priority-card-high-count"
                                  aria-label="@($"{highPriorityCount} high priority")">
                                @highPriorityCount high priority
                            </span>
                        }
                    </div>
                </header>

                @if (isEmpty)
                {
                    <ul class="priority-card__items">
                        <li class="priority-card__item" style="border: none; background: none; justify-items: center;">
                            <span style="color: var(--aura-on-surface-variant); font-size: 13px;">No items</span>
                        </li>
                    </ul>
                }
                else if (card.IsCalendarCard)
                {
                    <div class="priority-card__items">
                        @foreach (var ev in card.CalendarItems!.Take(3))
                        {
                            var status = PrioritySummaryService.GetEventStatus(ev);
                            <div class="schedule-item schedule-item--@status">
                                <div class="schedule-item__dot"></div>
                                <div class="schedule-item__content">
                                    <p class="schedule-item__time">@PrioritySummaryService.FormatTimeRange(ev)</p>
                                    <p class="schedule-item__title">@ev.Title</p>
                                    @if (ev.Location is not null)
                                    {
                                        <p class="schedule-item__location">@ev.Location</p>
                                    }
                                    @if (ev.IsOnlineMeeting && ev.JoinUrl is not null)
                                    {
                                        <a href="@ev.JoinUrl" class="schedule-item__join" target="_blank" rel="noopener noreferrer">Join</a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (card.IsPrCard)
                {
                    <div class="pr-mini-table-container">
                        <table class="pr-mini-table" data-testid="pr-mini-table">
                            <thead>
                                <tr>
                                    <th>PR Name</th>
                                    <th>Branch</th>
                                    <th>CI Status</th>
                                    <th>Reviews</th>
                                    <th>Last Activity</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in card.PrItems!.Take(3))
                                {
                                    <tr>
                                        <td>
                                            <span class="pr-mini-table__name">@item.PrDisplayName</span>
                                            <span class="pr-mini-table__author">@@@item.Author</span>
                                        </td>
                                        <td>
                                            <span class="pr-mini-table__branch">@item.BranchName</span>
                                        </td>
                                        <td>
                                            <span class="ci-status ci-status--@item.BuildStatus" data-testid="pr-ci-status">@item.BuildStatus</span>
                                        </td>
                                        <td>
                                            <div class="pr-mini-table__reviews">
                                                <span class="pr-mini-table__reviews-approved">@item.ReviewApprovals/@item.ReviewRequired Approved</span>
                                                @if (item.ReviewChangesRequested > 0)
                                                {
                                                    <span class="pr-mini-table__reviews-changes">@item.ReviewChangesRequested changes requested</span>
                                                }
                                                else if (item.ReviewApprovals < item.ReviewRequired && item.ReviewRequired > 0)
                                                {
                                                    <span class="pr-mini-table__reviews-needed">@(item.ReviewRequired - item.ReviewApprovals) needed</span>
                                                }
                                                @if (item.ReviewApprovals >= item.ReviewRequired && item.ReviewChangesRequested == 0)
                                                {
                                                    <span class="pr-mini-table__reviews-approved">✓ Approved</span>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <span class="pr-mini-table__time">@item.RelativeTimestamp</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <ul class="priority-card__items" data-testid="priority-card-preview-items">
                        @foreach (var item in card.PreviewItems!.Take(3))
                        {
                            <li class="priority-card__item" data-testid="priority-card-item">
                                <span class="priority-card__item-title" data-testid="priority-card-item-title"
                                      title="@item.Title">@item.Title</span>
                                <div class="priority-card__item-detail">
                                    @if (item.Sender is not null)
                                    {
                                        <span class="priority-card__item-sender" data-testid="priority-card-item-sender">
                                            @@@item.Sender
                                        </span>
                                    }
                                    @if (item.Snippet is not null)
                                    {
                                        <span class="priority-card__item-snippet" data-testid="priority-card-item-snippet"
                                              title="@item.Snippet">@item.Snippet</span>
                                    }
                                    <span data-testid="priority-card-item-time">@item.RelativeTimestamp</span>
                                    <span class="priority-card__item-action" data-testid="priority-card-item-action">
                                        @item.SuggestedAction
                                    </span>
                                </div>
                                @if (item.PriorityHint is not null)
                                {
                                    <PriorityBadge Level="@item.PriorityHint" />
                                }
                            </li>
                        }
                    </ul>
                }

                @if (!isEmpty && card.TotalCount > 3)
                {
                    <footer class="priority-card__footer">
                        @if (card.IsPrCard)
                        {
                            <div class="priority-card__footer-links">
                                <a href="@card.DetailPageUrl" class="priority-card__link" data-testid="priority-card-view-all">
                                    View all @card.TotalCount @card.ItemsLabel
                                    <span class="material-symbols-outlined" style="font-size: 14px;">arrow_forward</span>
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="priority-card__footer-links">
                                <a href="@card.DetailPageUrl" class="priority-card__link" data-testid="priority-card-view-all">
                                    View all @card.TotalCount @card.ItemsLabel
                                    <span class="material-symbols-outlined" style="font-size: 14px;">arrow_forward</span>
                                </a>
                                <a href="@card.ViewAllUrl" class="priority-card__link priority-card__link--source" data-testid="priority-card-view-source"
                                   target="_blank" rel="noopener noreferrer">
                                    @card.SourceLabel
                                    <span class="material-symbols-outlined" style="font-size: 14px;">open_in_new</span>
                                </a>
                            </div>
                        }
                    </footer>
                }
            </article>
        }
    }
</section>

@code {
    private List<PrioritySummaryCard>? _cards;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _cards = await PrioritySummaryService.GetCardsAsync(CancellationToken.None);
        }
        catch
        {
            _loadError = "Priority summary is currently unavailable.";
        }
    }
}
