@inject IDashboardPreviewApiClient DashboardPreviewApiClient

<section class="dashboard-panel" data-testid="inbox-preview-panel" aria-live="polite">
    <h2>Inbox preview</h2>
    <p>Latest items from connected sources.</p>

    @if (_loadError is not null)
    {
        <p role="alert" data-testid="inbox-preview-error">@_loadError</p>
    }
    else if (_response is null)
    {
        <p data-testid="inbox-preview-loading">Loading inbox preview...</p>
    }
    else if (_response.InboxGroups.Count == 0 || _response.InboxGroups.All(g => g.Items.Count == 0))
    {
        <p data-testid="inbox-preview-empty">No inbox items are available right now.</p>
    }
    else
    {
        <div data-testid="inbox-preview-populated">
            @foreach (var group in _response.InboxGroups)
            {
                <div class="inbox-preview-group">
                    <h3 data-testid="inbox-preview-group-source">@group.Source</h3>
                    <ul class="inbox-preview-list">
                        @foreach (var item in group.Items)
                        {
                            <li class="inbox-preview-item">
                                <span class="inbox-preview-item__title" data-testid="inbox-preview-item-title">@item.Title</span>
                                @if (item.Sender is not null)
                                {
                                    <span class="inbox-preview-item__sender" data-testid="inbox-preview-item-sender">@item.Sender</span>
                                }
                                @if (item.Snippet is not null)
                                {
                                    <span class="inbox-preview-item__snippet" data-testid="inbox-preview-item-snippet">@item.Snippet</span>
                                }
                                @if (item.DeepLink is not null)
                                {
                                    <a class="inbox-preview-item__deeplink" data-testid="inbox-preview-item-deeplink" href="@item.DeepLink" target="_blank" rel="noopener noreferrer">@item.DeepLink</a>
                                }
                                @if (item.SyncState is not null)
                                {
                                    <span class="inbox-preview-item__sync-state" data-testid="inbox-preview-item-sync-state">@item.SyncState</span>
                                }
                                <span class="inbox-preview-item__time">@item.RelativeTimestamp</span>
                                <span class="inbox-preview-item__action">@item.SuggestedAction</span>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    }
</section>

@code {
    private DashboardPreviewResponse? _response;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _response = await DashboardPreviewApiClient.GetPreviewAsync(CancellationToken.None);
        }
        catch
        {
            _loadError = "Inbox preview is currently unavailable.";
        }
    }
}
