@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@inject IConfiguration Configuration
@inject IJSRuntime JSRuntime
@inject ITokenAcquisitionService TokenService
@implements IAsyncDisposable

@if (_alerts.Count > 0)
{
    foreach (var alert in _alerts.ToArray())
    {
        var severityClass = SeverityClass(alert);
        var severityLabel = SeverityLabel(alert);
        var severityIcon = SeverityIcon(alert);
        <div class="toast toast--@severityClass" data-testid="work-item-toast-card">
            <div class="toast__icon">
                <span class="material-symbols-outlined">@severityIcon</span>
            </div>
            <div class="toast__body">
                <div class="toast__header">
                    <span class="toast__badge" data-testid="work-item-badge">@severityLabel</span>
                    <h3 class="toast__title" data-testid="work-item-title">@alert.Title</h3>
                    <button class="toast__dismiss"
                            data-testid="work-item-dismiss"
                            @onclick="() => DismissAlert(alert)"
                            aria-label="Dismiss alert">
                        &times;
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(alert.Reason))
                {
                    <p class="toast__source" data-testid="work-item-reason">@alert.Reason</p>
                }
                <div class="toast__actions">
                    <button class="toast__acknowledge"
                            data-testid="work-item-acknowledge"
                            @onclick="() => AcknowledgeAlert(alert)">
                        Acknowledge
                    </button>
                </div>
            </div>
        </div>
    }
}

@code {
    private HubConnection? _hubConnection;
    private readonly List<WorkItemAlertInfo> _alerts = [];
    private readonly object _lock = new();

    private static string SeverityClass(WorkItemAlertInfo alert)
    {
        if (alert is null) return "low";
        return alert.Priority switch
        {
            >= 8.0 => "critical",
            >= 6.0 => "high",
            >= 4.0 => "medium",
            _ => "low"
        };
    }

    private static string SeverityLabel(WorkItemAlertInfo alert)
    {
        if (alert is null) return "";
        return alert.Priority switch
        {
            >= 8.0 => "Critical",
            >= 6.0 => "High",
            >= 4.0 => "Medium",
            _ => "Info"
        };
    }

    private static string SeverityIcon(WorkItemAlertInfo alert)
    {
        if (alert is null) return "notifications";
        return alert.Priority switch
        {
            >= 8.0 => "error",
            >= 6.0 => "warning",
            >= 4.0 => "info",
            _ => "notifications"
        };
    }

    protected override async Task OnInitializedAsync()
    {
        await TryConnectWithRetryAsync();
    }

    private async Task TryConnectWithRetryAsync(int maxRetries = 3, int delayMs = 1000)
    {
        for (int attempt = 1; attempt <= maxRetries; attempt++)
        {
            try
            {
                var token = await TokenService.AcquireTokenAsync();

                if (string.IsNullOrEmpty(token))
                {
                    Console.WriteLine($"SignalR: Token not available for toast (attempt {attempt}/{maxRetries})");
                    if (attempt < maxRetries)
                        await Task.Delay(delayMs);
                    continue;
                }

                var baseUrl = Configuration.GetValue<string>("AuraApi:BaseUrl")?.TrimEnd('/')
                              ?? string.Empty;
                var hubUrl = string.IsNullOrEmpty(baseUrl)
                    ? "/hubs/alerts"
                    : $"{baseUrl}/hubs/alerts";

                _hubConnection = new HubConnectionBuilder()
                    .WithUrl(hubUrl, options =>
                    {
                        options.AccessTokenProvider = () => Task.FromResult(token)!;
                    })
                    .WithAutomaticReconnect()
                    .Build();

                _hubConnection.On<WorkItemAlertInfo>("UrgentWorkItem", alert =>
                {
                    lock (_lock)
                    {
                        _alerts.Add(alert);
                    }
                    InvokeAsync(async () =>
                    {
                        StateHasChanged();
                        await ShowBrowserNotification(alert);
                        await PlayAlertSound();
                    });
                });

                await _hubConnection.StartAsync();
                Console.WriteLine("SignalR: Toast connection established");
                return; // Success
            }
            catch (Exception ex)
            {
                Console.WriteLine($"SignalR: Toast connection failed (attempt {attempt}/{maxRetries}): {ex.Message}");
                if (attempt < maxRetries)
                    await Task.Delay(delayMs);
            }
        }

        Console.WriteLine("SignalR: Failed to establish toast connection after all retries - alerts will not be shown");
    }

    private async Task ShowBrowserNotification(WorkItemAlertInfo alert)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("workItemAlert.showNotification",
                alert.Title, alert.Reason ?? $"{SeverityLabel(alert)} priority");
        }
        catch (JSException)
        {
            // JS interop not available (e.g., during prerendering)
        }
    }

    private async Task PlayAlertSound()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("workItemAlert.playSound");
        }
        catch (JSException)
        {
            // JS interop not available
        }
    }

    private async Task AcknowledgeAlert(WorkItemAlertInfo alert)
    {
        if (_hubConnection is not null)
        {
            try
            {
                await _hubConnection.InvokeAsync("AcknowledgeWorkItem", alert.Id);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Failed to acknowledge work item alert: {ex.Message}");
            }
        }

        lock (_lock)
        {
            _alerts.Remove(alert);
        }
        StateHasChanged();
    }

    private void DismissAlert(WorkItemAlertInfo alert)
    {
        lock (_lock)
        {
            _alerts.Remove(alert);
        }
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

    public class WorkItemAlertInfo
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string SourceType { get; set; } = string.Empty;
        public double Priority { get; set; }
        public string? TriggerRule { get; set; }
        public string? Reason { get; set; }
    }
}
