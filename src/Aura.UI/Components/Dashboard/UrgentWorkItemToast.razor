@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@inject IConfiguration Configuration
@inject IJSRuntime JSRuntime
@inject ITokenAcquisitionService TokenService
@implements IAsyncDisposable

<div class="urgent-work-item-toast" data-testid="urgent-work-item-toast">
    @if (_currentAlert is not null)
    {
        <div class="urgent-work-item-toast__content" data-testid="urgent-work-item-toast-content">
            <div class="urgent-work-item-toast__header">
                <span class="urgent-work-item-toast__badge" data-testid="work-item-badge">Urgent</span>
                <h3 data-testid="work-item-title">@_currentAlert.Title</h3>
                <button class="urgent-work-item-toast__dismiss"
                        data-testid="work-item-dismiss"
                        @onclick="DismissAlert"
                        aria-label="Dismiss alert">
                    &times;
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_currentAlert.Decision))
            {
                <p class="urgent-work-item-toast__decision" data-testid="work-item-decision">
                    Priority: @_currentAlert.Decision
                </p>
            }
            <div class="urgent-work-item-toast__actions">
                <button class="urgent-work-item-toast__acknowledge"
                        data-testid="work-item-acknowledge"
                        @onclick="AcknowledgeAlert">
                    Acknowledge
                </button>
            </div>
        </div>
    }
</div>

@code {
    private HubConnection? _hubConnection;
    private WorkItemAlertInfo? _currentAlert;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var token = await TokenService.AcquireTokenAsync();

            var baseUrl = Configuration.GetValue<string>("AuraApi:BaseUrl")?.TrimEnd('/')
                          ?? string.Empty;
            var hubUrl = string.IsNullOrEmpty(baseUrl)
                ? "/hubs/alerts"
                : $"{baseUrl}/hubs/alerts";

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(hubUrl, options =>
                {
                    options.AccessTokenProvider = () => Task.FromResult(token)!;
                })
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<WorkItemAlertInfo>("UrgentWorkItem", alert =>
            {
                _currentAlert = alert;
                InvokeAsync(async () =>
                {
                    StateHasChanged();
                    await ShowBrowserNotification(alert);
                    await PlayAlertSound();
                });
            });

            await _hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to establish SignalR connection: {ex.Message}");
        }
    }

    private async Task ShowBrowserNotification(WorkItemAlertInfo alert)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("workItemAlert.showNotification",
                alert.Title, alert.Decision ?? "Urgent work item");
        }
        catch (JSException)
        {
            // JS interop not available (e.g., during prerendering)
        }
    }

    private async Task PlayAlertSound()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("workItemAlert.playSound");
        }
        catch (JSException)
        {
            // JS interop not available
        }
    }

    private async Task AcknowledgeAlert()
    {
        if (_hubConnection is not null && _currentAlert is not null)
        {
            try
            {
                await _hubConnection.InvokeAsync("AcknowledgeWorkItem", _currentAlert.Id);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Failed to acknowledge work item alert: {ex.Message}");
            }
        }

        _currentAlert = null;
        StateHasChanged();
    }

    private void DismissAlert()
    {
        _currentAlert = null;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

    public class WorkItemAlertInfo
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string? Decision { get; set; }
    }
}
