@using Aura.UI.Services

<header class="dashboard-header" data-testid="dashboard-header">
    <div class="dashboard-header__identity">
        <span class="dashboard-header__brand">Aura</span>
        <nav class="dashboard-header__nav">
            <button class="dashboard-header__nav-active dashboard-header__top-priority-link"
                    data-testid="header-top-priority-counter"
                    @onclick="NavigateToTopPriority"
                    title="Open top priority queue">
                Top priority queue
            </button>
        </nav>
    </div>

    <div class="dashboard-header__actions">
        <FocusStateBadge />
        <span class="material-symbols-outlined dashboard-header__icon-btn">terminal</span>
        <span class="material-symbols-outlined dashboard-header__icon-btn">settings</span>
        @if (!string.IsNullOrEmpty(UserDisplayName))
        {
            <span class="dashboard-header__user" data-testid="dashboard-header-user">@UserDisplayName</span>
        }
        <button class="dashboard-header__icon-btn" @onclick="HandleSignOut" data-testid="sign-out-btn" title="Sign out">
            <span class="material-symbols-outlined">logout</span>
        </button>
    </div>
</header>

@code {
    [Parameter]
    public string UserDisplayName { get; set; } = string.Empty;

    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private IConfiguration Configuration { get; set; } = default!;

    private void NavigateToTopPriority()
        => Navigation.NavigateTo("/top-priority");

    private void HandleSignOut()
    {
        // Redirect to the /logout endpoint which handles server-side sign-out.
        // Cannot call SignOutAsync from Blazor Server because the HTTP response
        // has already started (SignalR circuit).
        var useEntraId = Configuration.GetValue<bool>("UseEntraId");
        Navigation.NavigateTo($"/logout?useEntraId={useEntraId.ToString().ToLowerInvariant()}", forceLoad: true);
    }
}
