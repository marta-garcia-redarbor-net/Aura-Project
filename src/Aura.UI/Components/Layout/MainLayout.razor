@attribute [StreamRendering]
@implements IDisposable
@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView>
    <Authorized>
        <MainLayoutAuthenticated>
            @Body
        </MainLayoutAuthenticated>
    </Authorized>
    <NotAuthorized>
        @Body
    </NotAuthorized>
</AuthorizeView>

@code {
    public void Dispose() { }
}
