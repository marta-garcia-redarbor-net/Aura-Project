@using Microsoft.JSInterop
@using Aura.UI.Services
@using System.Net.Http
@inject Aura.UI.Services.AppVersionService AppVersion
@inject DemoUiState DemoState
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IHttpClientFactory HttpClientFactory
@inject IDashboardEventBus EventBus

<aside class="dashboard-sidebar" data-testid="dashboard-sidebar" aria-label="Dashboard navigation">
    <div class="dashboard-sidebar__brand">
    </div>

    <nav>
        <ul class="dashboard-sidebar__nav">
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/dashboard" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">dashboard</span>
                    Dashboard
                </NavLink>
            </li>
            <!-- Top Priority Queue entry removed for demo simplification.
                 Page and components kept for future re-enable. -->
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/teams" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">forum</span>
                    Teams Messages
                </NavLink>
            </li>
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/outlook" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">mail</span>
                    Pending Mail
                </NavLink>
            </li>
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/calendar/day" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">calendar_today</span>
                    Calendar
                </NavLink>
            </li>
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/pull-requests" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">account_tree</span>
                    Pull Requests
                </NavLink>
            </li>
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/triage/decisions" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">history</span>
                    Interruption Log
                </NavLink>
            </li>
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/logs" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">terminal</span>
                    Logs
                </NavLink>
            </li>
        </ul>
    </nav>

    <!-- Mobile-only actions (shown inside sidebar drawer at ≤900px) -->
    <div class="sidebar-mobile-actions" data-testid="sidebar-mobile-actions">
        @if (DemoState.IsDemoUser)
        {
            <div class="sidebar-mobile-actions__demo">
                <button class="dashboard-header__demo-btn"
                        disabled="@DemoState.SimulationRunning"
                        @onclick="HandleStartDemo"
                        title="Start demo simulation">
                    <span class="material-symbols-outlined">play_arrow</span>
                    Demo Mode
                </button>
                <button class="dashboard-header__reset-btn"
                        disabled="@DemoState.SimulationRunning"
                        @onclick="HandleResetDemo"
                        title="Delete demo items">
                    <span class="material-symbols-outlined">refresh</span>
                    Reset
                </button>
            </div>
        }

        @if (!DemoState.IsDemoUser)
        {
            <div class="sidebar-mobile-actions__focus">
                <FocusStateBadge />
            </div>
        }

        <div class="sidebar-mobile-actions__footer">
            <button class="sidebar-mobile-actions__icon-btn" title="Settings">
                <span class="material-symbols-outlined">settings</span>
            </button>
            <button class="sidebar-mobile-actions__icon-btn sidebar-mobile-actions__signout"
                    @onclick="HandleSignOut"
                    title="Sign out">
                <span class="material-symbols-outlined">logout</span>
                <span class="sidebar-mobile-actions__signout-label">Sign out</span>
            </button>
        </div>
    </div>

    <small class="dashboard-sidebar__version">@AppVersion.DisplayVersion</small>
</aside>

@code {
    private async Task HandleStartDemo()
    {
        try
        {
            DemoState.SimulationRunning = true;

            var client = HttpClientFactory.CreateClient("AuraApi");
            var response = await client.PostAsync("api/demo/start-simulation", null);
            response.EnsureSuccessStatusCode();

            DemoState.DemoDataExists = true;
            DemoState.ShowResetHint = true;

            // Auto-hide reset hint after 5 seconds
            _ = Task.Run(async () =>
            {
                await Task.Delay(5000);
                DemoState.ShowResetHint = false;
                await DemoState.NotifyStateChangedAsync();
            });
        }
        catch
        {
            // Silently handle errors
        }
        finally
        {
            DemoState.SimulationRunning = false;
            await DemoState.NotifyStateChangedAsync();
            await EventBus.RaiseDashboardRefreshAsync();
        }

        await CloseDrawer();
    }

    private async Task HandleResetDemo()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("AuraApi");
            await client.PostAsync("api/demo/reset", null);
            DemoState.DemoDataExists = false;
            DemoState.ShowResetHint = false;
            EventBus.ClearTracking();
        }
        catch
        {
            // Silently handle errors
        }
        finally
        {
            await DemoState.NotifyStateChangedAsync();
            await EventBus.RaiseDashboardRefreshAsync();
        }

        await CloseDrawer();
    }

    private void HandleSignOut()
    {
        _ = CloseDrawer();
        Navigation.NavigateTo("/logout", forceLoad: true);
    }

    private async Task CloseDrawer()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("sidebarDrawer.closeDrawer");
        }
        catch (JSException)
        {
            // JS interop not available
        }
    }
}
