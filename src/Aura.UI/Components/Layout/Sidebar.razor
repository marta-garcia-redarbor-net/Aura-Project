@inject Aura.UI.Services.AppVersionService AppVersion

<aside class="dashboard-sidebar" data-testid="dashboard-sidebar" aria-label="Dashboard navigation">
    <div class="dashboard-sidebar__brand">
    </div>

    <nav>
        <ul class="dashboard-sidebar__nav">
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/dashboard" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">dashboard</span>
                    Dashboard
                </NavLink>
            </li>
            <!-- Top Priority Queue entry removed for demo simplification.
                 Page and components kept for future re-enable. -->
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/teams" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">forum</span>
                    Teams Messages
                </NavLink>
            </li>
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/outlook" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">mail</span>
                    Pending Mail
                </NavLink>
            </li>
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/calendar/day" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">calendar_today</span>
                    Calendar
                </NavLink>
            </li>
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/pull-requests" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">account_tree</span>
                    Pull Requests
                </NavLink>
            </li>
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/triage/decisions" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">history</span>
                    Interruption Log
                </NavLink>
            </li>
            <li>
                <NavLink class="dashboard-sidebar__nav-item" href="/logs" ActiveClass="dashboard-sidebar__nav-item--active">
                    <span class="material-symbols-outlined dashboard-sidebar__nav-icon">terminal</span>
                    Logs
                </NavLink>
            </li>
        </ul>
    </nav>
    <small class="dashboard-sidebar__version">@AppVersion.DisplayVersion</small>
</aside>
