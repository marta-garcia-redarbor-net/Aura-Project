@page "/dashboard"
@using Aura.UI.Components.Dashboard
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using System.Net.Http.Json
@using Aura.UI.Components.Auth
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory

<AuthorizeView>
    <Authorized>
        <PageTitle>Aura Dashboard</PageTitle>

        <div class="dashboard-page-header">
            <div>
                <h1 class="dashboard-page-header__title">System Status</h1>
                <p class="dashboard-page-header__subtitle">Real-time telemetry and service heartbeat.</p>
            </div>
            <span class="dashboard-page-header__badge dashboard-page-header__badge--live">
                <span class="dashboard-page-header__badge-dot"></span>
                Live Sync
            </span>
        </div>

        @if (_demoAvailable)
        {
            <div class="demo-bar">
                <span class="demo-bar__label">🧪 Modo Demo</span>
                <button class="btn btn-sm btn-outline-primary" disabled="@_simulationRunning" @onclick="StartSimulationAsync">
                    @if (_simulationRunning)
                    {
                        <span>⏳ Iniciando…</span>
                    }
                    else
                    {
                        <span>▶ Iniciar Simulación</span>
                    }
                </button>
                @if (!string.IsNullOrEmpty(_simulationMessage))
                {
                    <span class="demo-bar__message">@_simulationMessage</span>
                }
            </div>
        }

        <DashboardStatePanel State="@State" />
        <GraphConnectorStatusPanel />
        <SystemStatusPanel />
        <FocusStatePanel />
        <ModuleProgressPanel />
        <DashboardCards Cards="@State.Cards" />
        <InboxPreviewPanel />
        <UpcomingMeetingsPanel />
        <SyncStatusPanel />
        <MorningSummaryPreviewPanel />
    </Authorized>
    <NotAuthorized>
        <PageTitle>Aura | Acceso Requerido</PageTitle>
        <RedirectToLanding />
    </NotAuthorized>
</AuthorizeView>

@code {
    private DashboardViewState _state = DashboardViewState.Loading();

    [CascadingParameter]
    public DashboardViewState State { get; set; } = DashboardViewState.Loading();

    private bool _demoAvailable;
    private bool _simulationRunning;
    private string? _simulationMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("AuraApi");
            var status = await client.GetFromJsonAsync<DemoStatus>("api/demo/status");
            _demoAvailable = status?.Enabled == true;
        }
        catch
        {
            _demoAvailable = false;
        }
    }

    private async Task StartSimulationAsync()
    {
        _simulationRunning = true;
        _simulationMessage = null;
        try
        {
            var client = HttpClientFactory.CreateClient("AuraApi");
            var response = await client.PostAsync("api/demo/start-simulation", null);
            response.EnsureSuccessStatusCode();
            _simulationMessage = "✅ Simulación iniciada — los datos llegarán gradualmente";
        }
        catch (Exception ex)
        {
            _simulationMessage = $"❌ Error: {ex.Message}";
        }
        finally
        {
            _simulationRunning = false;
        }
    }

    private sealed record DemoStatus(bool Enabled);
}
