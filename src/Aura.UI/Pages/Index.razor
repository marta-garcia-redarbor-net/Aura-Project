@page "/"

<PageTitle>Aura Dashboard</PageTitle>

<div class="dashboard-page-header">
    <div>
        <h1 class="dashboard-page-header__title">System Status</h1>
        <p class="dashboard-page-header__subtitle">Real-time telemetry and service heartbeat.</p>
    </div>
    <span class="dashboard-page-header__badge dashboard-page-header__badge--live">
        <span class="dashboard-page-header__badge-dot"></span>
        Live Sync
    </span>
</div>

<DashboardStatePanel State="@State" />
<DashboardCards Cards="@State.Cards" />

@code {
    [CascadingParameter]
    public DashboardViewState State { get; set; } = DashboardViewState.Loading();
}
