@page "/triage/decisions"
@using Aura.UI.Components.Auth
@using Microsoft.AspNetCore.Components.Authorization
@inject IDecisionLogApiClient DecisionLogApiClient
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        <PageTitle>Aura - Interruption Log</PageTitle>

        <div class="dashboard-page-header">
            <div>
                <h1 class="dashboard-page-header__title">Interruption Log</h1>
                <p class="dashboard-page-header__subtitle">Audit trail of interruption decisions.</p>
            </div>
            @if (_data is not null)
            {
                <span class="dashboard-page-header__badge dashboard-page-header__badge--live">
                    <span class="dashboard-page-header__badge-dot"></span>
                    @_data.TotalCount TOTAL
                </span>
            }
        </div>

        @if (_isLoading)
        {
            <section class="dashboard-panel dashboard-panel--loading" data-testid="decision-log-loading">
                <p>Loading interruption decisions...</p>
            </section>
        }
        else if (_error is not null)
        {
            <section class="dashboard-panel dashboard-panel--error" data-testid="decision-log-error">
                <p role="alert">@_error</p>
                <button class="decision-log__retry" data-testid="decision-log-retry" @onclick="LoadAsync">Retry</button>
            </section>
        }
        else if (_data is null || _data.Items.Count == 0)
        {
            <section class="dashboard-panel" data-testid="decision-log-empty">
                <div class="dashboard-card__empty-state" style="text-align:center;padding:2rem;">
                    <span class="material-symbols-outlined" style="font-size:48px;color:var(--aura-status-healthy);opacity:0.8;">history_toggle_off</span>
                    <h3 style="margin:0.5rem 0 0.25rem;">No interruptions logged yet</h3>
                    <p style="color:var(--aura-on-surface-variant);">Everything is quiet for now. New interruption decisions will appear here automatically.</p>
                </div>
            </section>
        }
        else
        {
            <section class="dashboard-panel" data-testid="decision-log-populated">
                <table class="decision-log-table" data-testid="decision-log-table">
                    <thead>
                        <tr>
                            <th class="decision-log-table__th--expand"></th>
                            <th class="decision-log-table__th--timestamp">Timestamp</th>
                            <th class="decision-log-table__th--title">Title</th>
                            <th class="decision-log-table__th--source">Source</th>
                            <th class="decision-log-table__th--score">Score</th>
                            <th class="decision-log-table__th--decision">Decision</th>
                            <th class="decision-log-table__th--focus">Focus</th>
                            <th class="decision-log-table__th--explanation">Explanation</th>
                            <th class="decision-log-table__th--guardrail">Guardrail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _data.Items)
                        {
                            <tr class="decision-log-table__row" data-testid="decision-log-row">
                                <td colspan="9" class="decision-log-table__details-cell">
                                    <details class="decision-trace" data-testid="decision-trace-details">
                                        <summary class="decision-trace__summary" data-testid="decision-trace-summary">
                                            <span class="decision-trace__grid">
                                                <span class="decision-trace__col--chevron">▶</span>
                                                <span class="decision-trace__col--timestamp">@item.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                                <span class="decision-trace__col--title">@item.Title</span>
                                                <span class="decision-trace__col--source">@item.SourceType</span>
                                                <span class="decision-trace__col--score">@(item.PriorityScore?.ToString() ?? "-")</span>
                                                <span class="decision-trace__col--decision">@item.Decision</span>
                                                <span class="decision-trace__col--focus">@item.FocusState</span>
                                                <span class="decision-trace__col--explanation">@item.Explanation</span>
                                                <span class="decision-trace__col--guardrail">
                                                    <span class="decision-trace__guardrail-badge decision-trace__guardrail-badge--@NormalizeGuardrail(item.GuardrailOutcome)">
                                                        @NormalizeGuardrail(item.GuardrailOutcome)
                                                    </span>
                                                </span>
                                            </span>
                                        </summary>

                                        <div class="decision-trace__panel" data-testid="decision-trace-panel">
                                            <section class="decision-trace__section" data-testid="decision-trace-section-summary">
                                                <h4>Final Verdict</h4>
                                                <p><strong>Decision:</strong> @item.Decision</p>
                                                <p><strong>Guardrail:</strong> @NormalizeGuardrail(item.GuardrailOutcome)</p>
                                            </section>

                                            <section class="decision-trace__section" data-testid="decision-trace-section-rules">
                                                <h4>Rules Fired</h4>
                                                <p>@item.Explanation</p>
                                            </section>

                                            <section class="decision-trace__section" data-testid="decision-trace-section-rationale">
                                                <h4>LLM Rationale</h4>
                                                <p>@(string.IsNullOrWhiteSpace(item.LlmRationale) ? "No LLM rationale recorded." : item.LlmRationale)</p>
                                            </section>

                                            <section class="decision-trace__section" data-testid="decision-trace-section-context">
                                                <h4>Semantic Context</h4>
                                                <details class="decision-trace__context-details" data-testid="decision-trace-context-details">
                                                    <summary>
                                                        @((item.RetrievedSemanticContext?.Count ?? 0) == 0
                                                            ? "No retrieved context items"
                                                            : $"{item.RetrievedSemanticContext!.Count} retrieved context items")
                                                    </summary>

                                                    @if (item.RetrievedSemanticContext is { Count: > 0 })
                                                    {
                                                        <ol class="decision-trace__context-list">
                                                            @foreach (var contextItem in item.RetrievedSemanticContext.OrderByDescending(x => x.RelevanceScore))
                                                            {
                                                                <li>
                                                                    <div><strong>@contextItem.SourceType</strong> · @contextItem.CanonicalSourceId</div>
                                                    <div>@contextItem.ContentSnippet</div>
                                                                    <div>Score: @contextItem.RelevanceScore.ToString("0.00")</div>
                                                                </li>
                                                            }
                                                        </ol>
                                                    }
                                                </details>
                                            </section>
                                        </div>
                                    </details>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (_data.TotalPages > 1)
                {
                    <nav class="decision-log__pagination" data-testid="decision-log-pagination" aria-label="Decision log pages">
                        @for (var p = 1; p <= _data.TotalPages; p++)
                        {
                            <button class="decision-log__page @(p == _page ? "decision-log__page--active" : string.Empty)"
                                    @onclick="() => GoToPageAsync(p)">
                                @p
                            </button>
                        }
                    </nav>
                }
            </section>
        }
    </Authorized>
    <NotAuthorized>
        <PageTitle>Aura | Acceso Requerido</PageTitle>
        <RedirectToLanding />
    </NotAuthorized>
</AuthorizeView>

@code {
    private const int DefaultPageSize = 20;
    private int _page = 1;
    private bool _isLoading = true;
    private string? _error;
    private DecisionLogResponse? _data;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;

        try
        {
            _data = await DecisionLogApiClient.GetDecisionsAsync(_page, DefaultPageSize, CancellationToken.None);
        }
        catch (UnauthorizedAccessException)
        {
            Navigation.NavigateTo("/logout", forceLoad: true);
        }
        catch
        {
            _error = "Interruption decision log is currently unavailable.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string NormalizeGuardrail(string? guardrailOutcome)
    {
        if (string.IsNullOrWhiteSpace(guardrailOutcome))
        {
            return "confirmed";
        }

        return guardrailOutcome.Trim().ToLowerInvariant() switch
        {
            "adjusted" => "adjusted",
            "blocked" => "blocked",
            "llm-unavailable" => "llm-unavailable",
            _ => "confirmed"
        };
    }
}
