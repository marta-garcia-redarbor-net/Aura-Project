@using Microsoft.AspNetCore.SignalR.Client
@using Aura.UI.Services
@inject IConfiguration Configuration
@inject ITokenAcquisitionService TokenService
@inject IDashboardEventBus EventBus
@inject IDashboardRealtimeStatus RealtimeStatus
@implements IAsyncDisposable

@code {
    private HubConnection? _hubConnection;
    private bool _initialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ = InitializeAsync();
        }

        await Task.CompletedTask;
    }

    public async Task InitializeAsync()
    {
        if (_initialized) return;
        _initialized = true;
        await TryConnectWithRetryAsync();
    }

    private async Task TryConnectWithRetryAsync(int maxRetries = 3, int delayMs = 1000)
    {
        for (int attempt = 1; attempt <= maxRetries; attempt++)
        {
            try
            {
                RealtimeStatus.MarkAttempt($"connecting ({attempt}/{maxRetries})");
                var token = await TokenService.AcquireTokenAsync();
                
                if (string.IsNullOrEmpty(token))
                {
                    RealtimeStatus.MarkDisconnected("token-unavailable");
                    Console.WriteLine($"SignalR: Token not available (attempt {attempt}/{maxRetries})");
                    if (attempt < maxRetries)
                        await Task.Delay(delayMs);
                    continue;
                }

                var baseUrl = Configuration.GetValue<string>("AuraApi:BaseUrl")?.TrimEnd('/')
                              ?? string.Empty;
                var hubUrl = string.IsNullOrEmpty(baseUrl)
                    ? "/hubs/alerts"
                    : $"{baseUrl}/hubs/alerts";

                _hubConnection = new HubConnectionBuilder()
                    .WithUrl(hubUrl, options =>
                    {
                        options.AccessTokenProvider = () => Task.FromResult(token)!;
                    })
                    .WithAutomaticReconnect()
                    .Build();

                _hubConnection.On<object>("DashboardRefresh", _ =>
                {
                    InvokeAsync(async () => 
                    {
                        RealtimeStatus.MarkRefreshReceived();
                        await EventBus.RaiseDashboardRefreshAsync();
                    });
                });

                await _hubConnection.StartAsync();
                RealtimeStatus.MarkConnected();
                Console.WriteLine("SignalR: Dashboard connection established");
                return; // Success
            }
            catch (Exception ex)
            {
                RealtimeStatus.MarkDisconnected($"connect-failed: {ex.GetType().Name}");
                Console.WriteLine($"SignalR: Connection failed (attempt {attempt}/{maxRetries}): {ex.Message}");
                if (attempt < maxRetries)
                    await Task.Delay(delayMs);
            }
        }
        
        RealtimeStatus.MarkDisconnected("failed-all-retries");
        Console.WriteLine("SignalR: Failed to establish connection after all retries - dashboard will not receive real-time updates");
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
