{
  "UseEntraId": false,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AuraApi": {
    "BaseUrl": "http://localhost:5180"
  },
  "AzureAd": {
    "ClientId": "<entra-app-client-id>",
    "TenantId": "<entra-tenant-id>",
    "Scopes": ["openid", "profile", "email"]
  },
  "ConnectionStrings": {
    "AuraDb": "Server=<azure-sql-server>.database.windows.net;Database=AuraDb;User Id=<admin-user>;Password=<password>;TrustServerCertificate=True;"
  },
  "Persistence": {
    "Providers": {
      "FocusState": "EntityFramework",
      "InterruptionDecision": "EntityFramework",
      "AlertRule": "EntityFramework",
      "NotificationOutbox": "EntityFramework",
      "MeetingAlert": "EntityFramework",
      "MorningSummaryEmission": "EntityFramework",
      "WorkItem": "EntityFramework",
      "SemanticOutbox": "EntityFramework",
      "MsalTokenCache": "EntityFramework"
    }
  }
}
