{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "ClientId": "<entra-app-client-id>",
    "TenantId": "<entra-tenant-id>",
    "Scopes": ["openid", "profile", "email"]
  },
  "EntraId": {
  },
  "GraphConnector": {
    "Enabled": false,
    "TenantId": "",
    "ClientId": ""
  },
  "EmbeddingProvider": {
    "Provider": "Ollama",
    "Endpoint": "http://localhost:11434",
    "DeploymentName": "nomic-embed-text"
  },
  "LlmAdvisor": {
    "Enabled": false,
    "Provider": "Ollama",
    "Endpoint": "",
    "ModelId": "",
    "TimeoutSeconds": 10,
    "ConfidenceThreshold": 0.7
  },
  "ConnectionStrings": {
    "TokenCache": "Data Source=token_cache.db",
    "Aura": "Data Source=../../data/aura.db",
    "AuraDb": "Data Source=aura-ef-test.db"
  },
  "Persistence": {
    "Provider": "Sqlite"
  },
  "FocusState": {
    "WorkingHoursStart": "08:00",
    "WorkingHoursEnd": "18:00",
    "MeetingBufferMinutes": 5,
    "BlackoutPeriods": []
  },
  "RateLimiting": {
    "Default": { "PermitLimit": 100, "WindowSeconds": 60 },
    "Auth": { "PermitLimit": 50, "WindowSeconds": 60 }
  },
  "DemoMode": {
    "Enabled": true
  }
}
