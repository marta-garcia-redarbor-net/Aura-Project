{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "ClientId": "<entra-app-client-id>",
    "TenantId": "<entra-tenant-id>",
    "Scopes": ["openid", "profile", "email"]
  },
  "EntraId": {
    "ValidAudiences": [ "api://<entra-app-client-id>", "<entra-app-client-id>" ]
  },
  "GraphConnector": {
    "Enabled": false,
    "TenantId": "",
    "ClientId": ""
  },
  "EmbeddingProvider": {
    "Provider": "Ollama",
    "Endpoint": "http://localhost:11434",
    "DeploymentName": "nomic-embed-text"
  },
  "ConnectionStrings": {
    "TokenCache": "Data Source=token_cache.db",
    "Aura": "Data Source=../../data/aura.db"
  }
}
