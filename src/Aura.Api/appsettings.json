{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "ClientId": "<entra-app-client-id>",
    "TenantId": "<entra-tenant-id>",
    "Scopes": ["openid", "profile", "email"]
  },
  "EntraId": {
    "ValidAudiences": [ "api://<entra-app-client-id>", "<entra-app-client-id>" ]
  }
}
