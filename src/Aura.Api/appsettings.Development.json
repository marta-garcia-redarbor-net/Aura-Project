{
  "UseEntraId": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Qdrant": {
    "Host": "localhost",
    "GrpcPort": 6334
  },
  "EmbeddingProvider": {
    "Provider": "Ollama",
    "Endpoint": "http://localhost:11434",
    "DeploymentName": "nomic-embed-text"
  },
  "LlmAdvisor": {
    "Enabled": true,
    "Provider": "Ollama",
    "Endpoint": "http://localhost:11434",
    "ModelId": "llama3.2",
    "TimeoutSeconds": 30,
    "ConfidenceThreshold": 0.7
  },
  "ConnectionStrings": {
    "SemanticOutbox": "Data Source=semantic_outbox.db",
    "AuraDb": "Data Source=aura-ef-test.db"
  },
  "GraphConnector": {
    "Enabled": false,
    "TenantId": "",
    "ClientId": ""
  },
  "SeedData": {
    "Enabled": true
  },
  "Persistence": {
    "Provider": "EntityFramework"
  },
  "DemoMode": { "Enabled": true }
}
