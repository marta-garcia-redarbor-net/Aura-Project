# =============================================================================
# Aura Docker Local Development — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
#
# Required: AzureAd__ClientId, AzureAd__TenantId
# Optional: everything else has sensible defaults.
#
# ASP.NET Core reads env vars with __ as section separator.
# Example: AzureAd__ClientId=xxx maps to config["AzureAd:ClientId"]
# =============================================================================

# ---------------------------------------------------------------------------
# Entra ID / Azure AD (required for real auth)
# Maps to AzureAd section in appsettings.json
# ---------------------------------------------------------------------------
# Replace with your Entra ID App Registration values
AzureAd__ClientId=<your-entra-client-id>
AzureAd__TenantId=<your-entra-tenant-id>
AzureAd__Instance=https://login.microsoftonline.com/
AzureAd__Scopes="openid profile email"

# ---------------------------------------------------------------------------
# AuraApi base URL (UI → API communication)
# Maps to AuraApi:BaseUrl in appsettings.json
# In Docker, use http://aura-api:8080 for container-to-container
# On host, use http://localhost:5190
# ---------------------------------------------------------------------------
AuraApi__BaseUrl=http://aura-api:8080

# ---------------------------------------------------------------------------
# Qdrant vector store
# Maps to Qdrant section in appsettings.json
# ---------------------------------------------------------------------------
Qdrant__Host=aura-qdrant
Qdrant__HttpPort=6333
Qdrant__GrpcPort=6334

# ---------------------------------------------------------------------------
# Connection strings
# Maps to ConnectionStrings section in appsettings.json
# ---------------------------------------------------------------------------
ConnectionStrings__SemanticOutbox="Data Source=/data/semantic_outbox.db"
ConnectionStrings__Aura="Data Source=/data/aura.db"

# ---------------------------------------------------------------------------
# Ollama LLM & Embedding endpoints
# In Docker, use container name. On host, use localhost.
# ---------------------------------------------------------------------------
LlmAdvisor__Enabled=true
LlmAdvisor__Endpoint=http://aura-ollama:11434
LlmAdvisor__ModelId=llama3.2
EmbeddingProvider__Endpoint=http://aura-ollama:11434
EmbeddingProvider__DeploymentName=nomic-embed-text

# ---------------------------------------------------------------------------
# Graph Connector (disabled by default)
# Maps to GraphConnector section in appsettings.json
# Set to true with real credentials to enable live data
# ---------------------------------------------------------------------------
GraphConnector__Enabled=false
GraphConnector__TenantId=
GraphConnector__ClientId=

# ---------------------------------------------------------------------------
# Token cache — shared between API and Worker in Docker
# Maps to ConnectionStrings:TokenCache in appsettings.json
# In Docker, the volume mount ./data:/data provides /data/tokens/
# ---------------------------------------------------------------------------
ConnectionStrings__TokenCache="Data Source=/data/tokens/cache.db"

# ---------------------------------------------------------------------------
# Service ports (host-side mapping for docker-compose)
# ---------------------------------------------------------------------------
UI_PORT=5180
API_PORT=5190
